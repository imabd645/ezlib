use "main.ez" 

doc = PDF("test_output.pdf")
doc.addPage()

# Colors
RED = doc.rgb(255, 0, 0)
BLUE = doc.rgb(0, 0, 255)
GREEN = doc.rgb(0, 180, 0)

# Header
doc.header("EZPDF Production Test")

# Fonts
doc.setFont("Helvetica-Oblique")
doc.text(50, 770, "Testing shapes, colors, and fonts!", 14, BLUE)

# Shapes
doc.rect(50, 700, 100, 50, 2, RED)
doc.filledRect(200, 700, 100, 50, GREEN, RED, 3)
doc.circle(100, 600, 40, 2, BLUE, GREEN)

# Save
doc.save()
