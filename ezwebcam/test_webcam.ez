use "main.ez" 
use "auto"  as auto
use "notify" as notify

notify.alert("A webcam window will open! SPACE = Photo, R = Record, S = Stop Record, C = Copy, F = Format, ESC = Exit.", "Webcam App")

cam = Webcam("My EZ Webcam", 640, 480)
when cam.hwndCap == 0 {
    exit(1)
}

photo_count = 1
running = true

print("Webcam started! Waiting for input...")

while running {
    # Keep the camera window updating!
    cam.update()
    
    # SPACE: Take a photo
    when auto.is_down("space") {
        filename = "photo_" + str(photo_count) + ".bmp"
        cam.capturePhoto(filename)
        print("Captured: " + filename)
        photo_count = photo_count + 1
        wait(500)
    }
    
    # R: Start recording
    when auto.is_down("r") {
        print("Recording started...")
        cam.startRecording("video.avi")
        wait(500)
    }

    # S: Stop recording
    when auto.is_down("s") {
        print("Recording stopped.")
        cam.stopRecording()
        wait(500)
    }

    # C: Copy to clipboard
    when auto.is_down("c") {
        cam.copyToClipboard()
        print("Frame copied to clipboard!")
        wait(500)
    }

    # F: Show Format Dialog
    when auto.is_down("f") {
        cam.showFormatDialog()
        wait(500)
    }
    
    # ESCAPE: Exit
    when auto.is_down("escape") {
        print("Exiting...")
        running = false
    }
    
    wait(16)
}

cam.close()
notify.alert("Webcam closed safely.", "Done")
