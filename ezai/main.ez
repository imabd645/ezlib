# ============================================================
# ez-ai  —  AI Standard Library for EZ
# Version 1.0.1
#
# Uses synchronous http_post instead of fetch+await so it works
# correctly when called from inside a server() request thread.
# ============================================================

# ----------------------------------------------------------
# Internal Helpers
# ----------------------------------------------------------

export task _ai_post(url, headers, body)
{
    give http_post(url, to_json(body), headers)
}

export task _ai_safe_parse(raw, label)
{
    try
    {
        give parse_json(raw)
    }
    catch e
    {
        out "[ez-ai] Failed to parse " + label + " response: " + str(e)
        out "[ez-ai] Raw response was: " + str(raw)
        give nil
    }
}

export task _starts_with(s, prefix)
{
    when len(s) < len(prefix) { give false }
    give substr(s, 0, len(prefix)) == prefix
}

export task _has_error(data)
{
    when type(data) != "dictionary" { give false }
    ks = keys(data)
    get k in ks
    {
        when k == "error" { give true }
    }
    give false
}

# ----------------------------------------------------------
# OpenAI  (gpt-4o-mini, gpt-4o, etc.)
# ----------------------------------------------------------

export task openai(prompt, apiKey)
{
    give openai_full(prompt, apiKey, "gpt-4o-mini", nil)
}

export task openai_model(prompt, apiKey, mdl)
{
    give openai_full(prompt, apiKey, mdl, nil)
}

export task openai_full(prompt, apiKey, mdl, systemPrompt)
{
    url = "https://api.openai.com/v1/chat/completions"

    headers = {
        "Content-Type": "application/json",
        "Authorization": "Bearer " + apiKey
    }

    messages = []
    when systemPrompt != nil
    {
        push(messages, {"role": "system", "content": systemPrompt})
    }
    push(messages, {"role": "user", "content": prompt})

    body = {
        "model": mdl,
        "messages": messages
    }

    raw = _ai_post(url, headers, body)
    data = _ai_safe_parse(raw, "OpenAI")
    when data == nil { give nil }

    when _has_error(data)
    {
        out "[ez-ai] OpenAI error: " + str(data["error"]["message"])
        give nil
    }

    try { give data["choices"][0]["message"]["content"] }
    catch e
    {
        out "[ez-ai] Unexpected OpenAI response: " + str(e)
        give nil
    }
}

export task _openai_chat(messages, apiKey, mdl)
{
    url = "https://api.openai.com/v1/chat/completions"
    headers = {
        "Content-Type": "application/json",
        "Authorization": "Bearer " + apiKey
    }
    body = { "model": mdl, "messages": messages }

    raw = _ai_post(url, headers, body)
    data = _ai_safe_parse(raw, "OpenAI")
    when data == nil { give nil }
    when _has_error(data) { out "[ez-ai] OpenAI error: " + str(data["error"]["message"])   give nil }
    try { give data["choices"][0]["message"]["content"] }
    catch e { out "[ez-ai] Unexpected OpenAI response: " + str(e)   give nil }
}

