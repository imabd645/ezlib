    when systemPrompt != nil
    {
        push(messages, {"role": "system", "content": systemPrompt})
    }
    push(messages, {"role": "user", "content": prompt})

    body = {
        "model": mdl,
        "messages": messages
    }

    raw = _ai_post(url, headers, body)
